# Local dev uses SQLite (no setup needed):
DATABASE_URL="file:./dev.db"

# To deploy: switch prisma/schema.prisma provider to "postgresql",
# swap the adapter in lib/db.ts, and point this at a Postgres URL, e.g.:
# DATABASE_URL="postgresql://user:pass@host:5432/hackradar"

# Optional: protects the /api/cron endpoint. When set, the cron caller must send
# `Authorization: Bearer <CRON_SECRET>`. Vercel Cron does this automatically.
# CRON_SECRET="change-me"
